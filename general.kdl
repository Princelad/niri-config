prefer-no-csd

screenshot-path null

environment {
    QT_QPA_PLATFORM "wayland"
    QT_QPA_PLATFORMTHEME "qt6ct"
    QT_STYLE_OVERRIDE "kvantum"
}

cursor {
    xcursor-theme "Hackneyed-Dark"
    xcursor-size 24
    hide-after-inactive-ms 1000
}

clipboard {
    disable-primary
}

hotkey-overlay {
    skip-at-startup
}
