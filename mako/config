# Mako base config for niri. Pywal colors are loaded via include below.
font=FiraCode Nerd Font 11
width=360
height=140
margin=12
padding=10
border-size=2
border-radius=8
default-timeout=5000
ignore-timeout=0
layer=top
anchor=top-right
max-visible=6

format=<b>%s</b>\n%b

# Generated by pywal after each wal run.
include=~/.cache/wal/colors-mako
